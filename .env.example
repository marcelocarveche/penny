# ============================================
# PENNY - Variáveis de Ambiente
# ============================================

# === Database ===
# PostgreSQL local (Docker): use host "db"
# PostgreSQL local (sem Docker): use host "localhost"
# PostgreSQL remoto: use URL completa do provider
DATABASE_URL=postgresql://penny:penny_dev_password@db:5432/penny_db

# Credenciais do PostgreSQL (apenas para Docker local) - Alterar
POSTGRES_USER=penny
POSTGRES_PASSWORD=penny_dev_password
POSTGRES_DB=penny_db

# === Better Auth ===
# Gere com: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-key-here-change-this
BETTER_AUTH_URL=http://localhost:3000

# === Portas ===
APP_PORT=3000
DB_PORT=5432

# === Email (Opcional) ===
# Provider: Resend (https://resend.com)
RESEND_API_KEY=
RESEND_FROM_EMAIL="Penny <noreply@seudominio.com>"

# === OAuth (Opcional) ===
# Google: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# === Multi-Domínio (Opcional) ===
# Domínio público que serve apenas a landing page (apenas hostname, com ou sem protocolo/porta).
# Se não definido, todas as rotas ficam acessíveis.
# PUBLIC_DOMAIN=penny.com

# === Backup em Nuvem (Opcional) ===
# Remote configurado via: make setup-rclone
RCLONE_REMOTE=gdrive
RCLONE_PATH=penny/backups

# === AI Providers (Opcional) ===
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
OPENROUTER_API_KEY=